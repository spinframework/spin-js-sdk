{
    "compilerOptions": {
        "rootDir": "./src/",
        "outDir": "./dist/",
        "noImplicitAny": true,
        "module": "nodenext",
        "target": "es2020",
        "jsx": "react",
        "skipLibCheck": true,
        "lib": [
            "ES2020",
            "WebWorker"
        ],
        "allowJs": true,
        "strict": true,
        "noImplicitReturns": true,
        "moduleResolution": "nodenext"
    },
    "include": [
        "src/**/*",
        "types/**/*"
    ]
}