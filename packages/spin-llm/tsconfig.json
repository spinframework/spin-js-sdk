{
    "compilerOptions": {
        "rootDir": "./src",
        "target": "ES2022",
        "module": "nodenext",
        "lib": [
            "ES2022"
        ],
        "moduleResolution": "nodenext",
        "declaration": true,
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}